# Neon (or any standard Postgres) connection string — same database the
# web app reads from. Prefer the "Pooled connection" string from your
# Neon dashboard if you ever run several scrape jobs concurrently;
# for a single daily cron run the direct connection string is fine too.
DATABASE_URL=postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require
